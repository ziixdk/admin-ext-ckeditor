{
    "name": "ziixdk/admin-ext-ckeditor",
    "description": "Integrate CKEDITOR into ziix-admin",
    "type": "library",
    "keywords": [
        "ziix-admin",
        "open-admin",
        "wysiwyg",
        "extension",
        "editor",
        "CKEditor"
    ],
    "homepage": "https://github.com/ziixdk/admin-ext-ckeditor",
    "license": "MIT",
    "authors": [
        {
            "name": "Rasmus Hurup | ziix.dk",
            "email": "info@ziix.dk"
        }
    ],
    "require": {
        "php": ">=8.3.0",
        "laravel/framework": ">=7.0",
        "ziixdk/admin": ">=3.0.5"
    },
    "require-dev": {
        "phpunit/phpunit": "~6.0",
        "laravel/laravel": "~11.0"
    },
    "autoload": {
        "psr-4": {
            "ZiiX\\Admin\\CKEditor\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZiiX\\Admin\\CKEditor\\CKEditorServiceProvider"
            ]
        }
    }
}